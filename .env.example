APP_NAME="Powerblink FC"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://powerblinkfc.com

# One-time first admin at /bootstrap-admin — set true only briefly, then false
ADMIN_BOOTSTRAP_ENABLED=false

# Bootstrap admin created by PowerblinkDemoSeeder / SQL export (rotate before public launch)
BOOTSTRAP_ADMIN_EMAIL=info@powerblinkfc.com
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME="PowerBlink Admin"
# Demo portal accounts (coach/parent/player) — set only for staging exports; rotate before launch
DEMO_USER_PASSWORD=
PAYMENT_PENDING_REUSE_MINUTES=30

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- MySQL (required for production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=powerblink_academy
DB_USERNAME=powerblink
DB_PASSWORD=

# Local-only alternative:
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_FROM_ADDRESS="info@powerblinkfc.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_TO_ADMIN="info@powerblinkfc.com"

MAIL_PHPMAILER_ENABLED=true
MAIL_PHPMAILER_HOST=
MAIL_PHPMAILER_PORT=587
MAIL_PHPMAILER_USERNAME=
MAIL_PHPMAILER_PASSWORD=
MAIL_PHPMAILER_ENCRYPTION=tls

# Comma-separated proxy IPs for your host/load balancer (avoid * in production)
TRUSTED_PROXIES=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Paystack (registration payments)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
