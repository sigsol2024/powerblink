APP_NAME="Auto Torque Ltd"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://myautotorque.com

# HTTP import of demo sold inventory (Stylemix Motors) during migrate. Testing defaults to off via phpunit.xml.
# IMPORT_STYLEMIX_SOLD_LISTINGS=true

# One-time first admin at /bootstrap-admin — set true only briefly, then false (see database/README.md)
ADMIN_BOOTSTRAP_ENABLED=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# stack → LOG_STACK (usually "single" = storage/logs/laravel.log). Use "daily" for laravel-YYYY-MM-DD.log.
# LOG_LEVEL=error only writes error|critical|alert|emergency — no file until something hits that level (or use debug on staging).
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- MySQL (required for production; copy to .env and set credentials on the server) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=myauto_torque
DB_USERNAME=myauto_torque
# Required on the server: if empty, MySQL reports "using password: NO" and the site returns 500 (sessions use the DB too).
DB_PASSWORD=

# Local-only alternative (not for production deploy):
# DB_CONNECTION=sqlite
# # DB_DATABASE=/absolute/path/to/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_VENDOR_IDLE_TIMEOUT=15
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Outbound mail: PHPMailer SMTP (transactional email from the app) ---
# Laravel's MAIL_MAILER is not used by OutboundMailService; configure SMTP below.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@myautotorque.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_TO_ADMIN="hello@myautotorque.com"

# NHTSA vPIC catalog sync (listing-options:sync-vpic) — optional tuning; no API key.
# VPIC_BASE_URL=https://vpic.nhtsa.dot.gov/api
# VPIC_SYNC_DELAY_MS=300
# VPIC_TIMEOUT=15
# VPIC_RETRIES=3
# VPIC_RETRY_SLEEP_MS=500
# VPIC_USER_AGENT="MyAutoTorque/vPIC-Sync"
# Optional: replace config/vpic.php curated list entirely (comma-separated vPIC Make_ID integers).
# VPIC_ALLOWED_MAKE_IDS=448,474,460,469

MAIL_PHPMAILER_ENABLED=true
MAIL_PHPMAILER_HOST=
MAIL_PHPMAILER_PORT=587
MAIL_PHPMAILER_USERNAME=
MAIL_PHPMAILER_PASSWORD=
MAIL_PHPMAILER_ENCRYPTION=tls

TRUSTED_PROXIES=*

# Google OAuth (optional; leave blank to hide Google buttons on auth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
